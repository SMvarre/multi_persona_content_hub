# --- LLM provider: gemini | openrouter ---
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys) — OpenAI-compatible API
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model slug from https://openrouter.ai/models (examples below)
LLM_MODEL=google/gemini-2.0-flash-001
# LLM_MODEL=openai/gpt-4o-mini
# LLM_MODEL=anthropic/claude-3.5-haiku

# Google Gemini (direct) — only if LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=
# LLM_MODEL=gemini-2.0-flash

ENABLE_LLM=true
LLM_MAX_RETRIES=2

# Paths
DATA_DIR=data
UPLOAD_DIR=data/uploads
CHROMA_PERSIST_DIR=data/chroma

# Models & retrieval (defaults match app/config.py)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHUNK_SIZE=1400
CHUNK_OVERLAP=120
INGEST_BATCH_SIZE=128
TOP_K=6
AGENT_TOP_K=8
SIMILARITY_THRESHOLD=0.2

LOG_LEVEL=INFO

# Agent workflow
ENABLE_WEB_SEARCH=true
ENABLE_TOOL_CALLING=true
MAX_TOOL_ITERATIONS=2
DEFAULT_PERSONA_ID=research_analyst
WEB_SEARCH_MAX_RESULTS=5
